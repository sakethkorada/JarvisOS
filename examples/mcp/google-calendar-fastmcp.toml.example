# Local FastMCP Google Calendar config for JarvisOS.
# Requires FastMCP in the active environment:
# uv pip install fastmcp
#
# Before using this server, authenticate Google through JarvisOS once so your
# global auth profile points at a stored provider token:
# python -m jarvis auth debug google
#
# The MCP subprocess uses the global JarvisOS auth profile by default, so this
# config only enables the Calendar tools. Set JARVIS_AUTH_PROFILE or add
# [auth] to jarvis.toml/.jarvis/auth.toml when provider metadata is needed.

[[mcp.servers]]
name = "google_calendar"
command = "python"
args = [
  "examples/mcp/google_calendar_fastmcp_server.py",
  "--provider",
  "google",
]
risk_level = "low"
requires_approval = false

[[mcp.servers.tools]]
name = "list_calendars"
argument_hints = "No arguments are needed. Use this when the user asks which calendars are available."
risk_level = "low"
requires_approval = false

[[mcp.servers.tools]]
name = "list_events"
argument_hints = """
Use calendar_id = "primary" unless the user named a specific calendar.
For relative ranges, return RFC3339/ISO datetimes based on current_datetime.
If the user asks for upcoming events without a range, use the next 7 days.
"""
risk_level = "low"
requires_approval = false
